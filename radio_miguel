<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Radio Premium España - Local</title>
    
    <script src="https://cdn.jsdelivr.net/npm/hls.js@1"></script>

    <style>
        :root {
            --bg: #1a1a1a;
            --surface: #222222;
            --shadow-light: #2c2c2c;
            --shadow-dark: #111111;
            --accent: #00ffa3; 
            --text-main: #ffffff;
            --text-dim: #888888;
            --brand-color: #00ffa3;
            --alert-color: #ff4757;
        }

        body {
            font-family: -apple-system, sans-serif;
            background: var(--bg);
            color: var(--text-main);
            margin: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
            box-sizing: border-box;
        }

        .radio-chassis {
            background: var(--surface);
            padding: 25px;
            border-radius: 30px;
            width: 100%;
            max-width: 400px;
            box-shadow: 8px 8px 16px var(--shadow-dark), -8px -8px 16px var(--shadow-light);
        }

        .display {
            background: #0a0a0a;
            border-radius: 15px;
            padding: 20px;
            text-align: center;
            box-shadow: inset 4px 4px 10px #000, inset -2px -2px 5px #1a1a1a;
            margin-bottom: 25px;
            position: relative;
            border: 2px solid #333;
        }

        .station-name {
            font-size: 2.2rem;
            font-weight: 900;
            margin: 0;
            color: var(--brand-color);
            text-shadow: 0 0 10px var(--brand-color);
            transition: color 0.3s;
        }

        .freq-display {
            font-size: 0.85rem;
            color: var(--text-dim);
            font-family: monospace;
            margin-top: 8px;
            background: #111;
            padding: 4px 10px;
            border-radius: 10px;
            display: inline-block;
        }

        /* Alerta de AdBlock (Solo visible si Flumotion es bloqueado) */
        .adblock-alert {
            display: none;
            color: var(--alert-color);
            font-size: 0.75rem;
            font-weight: bold;
            margin-top: 10px;
            animation: pulse 1.5s infinite;
        }

        @keyframes pulse { 0% { opacity: 0.5; } 50% { opacity: 1; } 100% { opacity: 0.5; } }

        .visualizer {
            display: flex;
            align-items: flex-end;
            justify-content: center;
            height: 40px;
            gap: 4px;
            margin-top: 15px;
        }

        .bar { width: 8px; background: var(--accent); border-radius: 2px 2px 0 0; height: 5px; opacity: 0.3; transition: opacity 0.2s; }
        .playing .bar { opacity: 1; box-shadow: 0 0 8px var(--accent); animation: eqBounce 0.6s infinite alternate ease-in-out; }
        .playing .bar:nth-child(1) { animation-duration: 0.4s; }
        .playing .bar:nth-child(2) { animation-duration: 0.7s; animation-delay: 0.1s; }
        .playing .bar:nth-child(3) { animation-duration: 0.5s; animation-delay: 0.3s; }
        .playing .bar:nth-child(4) { animation-duration: 0.8s; animation-delay: 0.2s; }
        .playing .bar:nth-child(5) { animation-duration: 0.5s; animation-delay: 0.4s; }
        .playing .bar:nth-child(6) { animation-duration: 0.6s; animation-delay: 0.1s; }
        @keyframes eqBounce { 0% { height: 5px; } 100% { height: 35px; } }

        .dial-container { margin-bottom: 25px; }
        .dial-label { font-size: 0.75rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 2px; margin-bottom: 10px; display: block; text-align: center; }
        input[type=range] { -webkit-appearance: none; width: 100%; background: transparent; }
        input[type=range]::-webkit-slider-runnable-track { width: 100%; height: 8px; background: #111; border-radius: 4px; box-shadow: inset 1px 1px 3px #000; }
        input[type=range]::-webkit-slider-thumb { -webkit-appearance: none; height: 24px; width: 12px; border-radius: 3px; background: #555; cursor: pointer; margin-top: -8px; border: 1px solid #777; box-shadow: 0 0 5px rgba(0,0,0,0.5); }

        .controls-main { display: flex; justify-content: center; gap: 20px; margin-bottom: 25px; }
        .btn-neo {
            background: var(--surface); border: none; border-radius: 50%; width: 60px; height: 60px; color: var(--text-main); font-size: 1.2rem; cursor: pointer;
            box-shadow: 5px 5px 10px var(--shadow-dark), -5px -5px 10px var(--shadow-light); transition: all 0.2s ease; display: flex; align-items: center; justify-content: center;
        }
        .btn-neo:active, .btn-neo.active { box-shadow: inset 5px 5px 10px var(--shadow-dark), inset -5px -5px 10px var(--shadow-light); color: var(--accent); }
        .btn-neo.large { width: 80px; height: 80px; font-size: 1.8rem; }

        .tone-controls { display: flex; justify-content: space-between; margin-bottom: 20px; border-top: 1px solid #333; padding-top: 20px; }
        .knob-group { text-align: center; width: 45%; }

        .presets { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-top: 10px; margin-bottom: 15px;}
        .btn-preset { background: var(--surface); border: none; padding: 10px 5px; border-radius: 8px; color: var(--text-dim); font-size: 0.7rem; font-weight: bold; cursor: pointer; box-shadow: 3px 3px 6px var(--shadow-dark), -3px -3px 6px var(--shadow-light); }
        .btn-preset:active { box-shadow: inset 2px 2px 5px var(--shadow-dark); }

        .city-dropdown-wrapper { text-align: center; margin-bottom: 20px; }
        select.city-select {
            background-color: #1a1a1a; color: var(--brand-color); border: 1px solid #333; padding: 10px 12px; border-radius: 8px;
            font-size: 0.85rem; width: 100%; max-width: 250px; font-weight: bold; cursor: pointer; outline: none; box-shadow: inset 2px 2px 5px #000;
        }

        .sleep-timer { text-align: center; font-size: 0.8rem; color: var(--text-dim); border-top: 1px solid #333; padding-top: 15px;}
        .sleep-btn { background: transparent; border: 1px solid #444; color: #888; padding: 5px 15px; border-radius: 20px; margin-top: 5px; cursor: pointer; transition: 0.2s;}
        .sleep-btn:active { background: #333; }
    </style>
</head>
<body>

    <div class="radio-chassis">
        
        <div class="display" id="displayScreen">
            <div id="sleepIndicator" style="position: absolute; top: 10px; right: 15px; font-size: 0.6rem; color: #ff4757; display: none;">ZZZ 30m</div>
            <h1 class="station-name" id="stationName">SINTONIZANDO...</h1>
            <div class="freq-display" id="freqDisplay">📍 Vega Baja | FM 0.0 MHz</div>
            <div class="adblock-alert" id="adblockAlert">⚠️ Desactiva el Bloqueador de Anuncios</div>
            
            <div class="visualizer" id="eqVisualizer">
                <div class="bar"></div><div class="bar"></div><div class="bar"></div>
                <div class="bar"></div><div class="bar"></div><div class="bar"></div>
            </div>
        </div>

        <div class="dial-container">
            <span class="dial-label">Tuning / Sintonizador</span>
            <input type="range" id="freqDial" min="0" max="7" value="0" step="1" oninput="dialChanged()">
        </div>

        <div class="controls-main">
            <button class="btn-neo" onclick="stopRadio()" title="Stop">⏹</button>
            <button class="btn-neo large" id="playBtn" onclick="togglePlay()" title="Play/Pause">▶</button>
            <button class="btn-neo" id="muteBtn" onclick="toggleMute()" title="Mute">🔊</button>
        </div>

        <div class="tone-controls">
            <div class="knob-group">
                <span class="dial-label">BASS</span>
                <input type="range" min="0" max="100" value="50">
            </div>
            <div class="knob-group">
                <span class="dial-label">TREBLE</span>
                <input type="range" min="0" max="100" value="75">
            </div>
        </div>

        <span class="dial-label">PRESETS ESPAÑA</span>
        <div class="presets">
            <button class="btn-preset" onclick="setStation(0)">SER</button>
            <button class="btn-preset" onclick="setStation(1)">COPE</button>
            <button class="btn-preset" onclick="setStation(2)">O.CERO</button>
            <button class="btn-preset" onclick="setStation(3)">RNE</button>
            <button class="btn-preset" onclick="setStation(4)">LOS40</button>
            <button class="btn-preset" onclick="setStation(5)">C.100</button>
            <button class="btn-preset" onclick="setStation(6)">DIAL</button>
            <button class="btn-preset" onclick="setStation(7)">EUROPA</button>
        </div>

        <div class="city-dropdown-wrapper">
            <select id="citySelect" class="city-select" onchange="changeCity(this.value)"></select>
        </div>

        <div class="sleep-timer">
            SLEEP TIMER (APAGADO AUTO)
            <br>
            <button class="sleep-btn" onclick="setSleepTimer(15)">15m</button>
            <button class="sleep-btn" onclick="setSleepTimer(30)">30m</button>
            <button class="sleep-btn" onclick="setSleepTimer(60)">60m</button>
            <button class="sleep-btn" onclick="setSleepTimer(0)">OFF</button>
        </div>

    </div>

    <audio id="radioPlayer" preload="none"></audio>

    <script>
        const stations = [
            {
                name: "CADENA SER", color: "#FFD700",
                locations: [
