                    { city: "Valencia", freq: "100.4", url: "https://playerservices.streamtheworld.com/api/livestream-redirect/CADENASER.mp3" },
                    { city: "Sevilla", freq: "103.2", url: "https://playerservices.streamtheworld.com/api/livestream-redirect/CADENASER.mp3" },
                    { city: "Murcia", freq: "100.3", url: "https://playerservices.streamtheworld.com/api/livestream-redirect/CADENASER.mp3" }
                ]
            },
            {
                name: "COPE", color: "#0055A4", 
                // Convertido a HLS puro para evadir bloqueos agresivos a MP3
                locations: [
