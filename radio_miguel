                    { city: "Madrid", freq: "106.3", url: "https://flucast09-h-cloud.flumotion.com/cope/net1.m3u8" },
                    { city: "Barcelona", freq: "102.0", url: "https://flucast09-h-cloud.flumotion.com/cope/net1.m3u8" },
                    { city: "Valencia", freq: "92.0", url: "https://flucast09-h-cloud.flumotion.com/cope/net1.m3u8" },
                    { city: "Sevilla", freq: "99.6", url: "https://flucast09-h-cloud.flumotion.com/cope/net1.m3u8" },
                    { city: "Murcia", freq: "106.9", url: "https://flucast09-h-cloud.flumotion.com/cope/net1.m3u8" }
                ]
            },
            {
                name: "ONDA CERO", color: "#009933", 
                locations: [
                    { city: "Vega Baja", freq: "90.3", url: "https://atres-live.ondacero.es/live/ondacero/bitrate_1.m3u8" },
                    { city: "Madrid", freq: "98.0", url: "https://atres-live.ondacero.es/live/ondacero/bitrate_1.m3u8" },
                    { city: "Barcelona", freq: "93.5", url: "https://atres-live.ondacero.es/live/ondacero/bitrate_1.m3u8" },
                    { city: "Valencia", freq: "101.2", url: "https://atres-live.ondacero.es/live/ondacero/bitrate_1.m3u8" },
                    { city: "Sevilla", freq: "95.9", url: "https://atres-live.ondacero.es/live/ondacero/bitrate_1.m3u8" },
                    { city: "Murcia", freq: "92.3", url: "https://atres-live.ondacero.es/live/ondacero/bitrate_1.m3u8" }
                ]
            },
            {
                name: "RNE 1", color: "#FF0000",
                locations: [
                    { city: "Alicante", freq: "105.2", url: "https://dispatcher.rndfnk.com/crtve/rne1/mad/mp3/high" },
                    { city: "Madrid", freq: "104.9", url: "https://dispatcher.rndfnk.com/crtve/rne1/mad/mp3/high" },
                    { city: "Barcelona", freq: "73.8", url: "https://dispatcher.rndfnk.com/crtve/rne1/mad/mp3/high" },
                    { city: "Valencia", freq: "89.8", url: "https://dispatcher.rndfnk.com/crtve/rne1/mad/mp3/high" },
                    { city: "Sevilla", freq: "93.3", url: "https://dispatcher.rndfnk.com/crtve/rne1/mad/mp3/high" },
                    { city: "Murcia", freq: "87.9", url: "https://dispatcher.rndfnk.com/crtve/rne1/mad/mp3/high" }
                ]
            },
            {
                name: "LOS 40", color: "#FF00FF",
                locations: [
                    { city: "Vega Baja", freq: "101.4", url: "https://playerservices.streamtheworld.com/api/livestream-redirect/LOS40.mp3" },
                    { city: "Madrid", freq: "93.9", url: "https://playerservices.streamtheworld.com/api/livestream-redirect/LOS40.mp3" },
                    { city: "Barcelona", freq: "93.9", url: "https://playerservices.streamtheworld.com/api/livestream-redirect/LOS40.mp3" },
                    { city: "Valencia", freq: "94.2", url: "https://playerservices.streamtheworld.com/api/livestream-redirect/LOS40.mp3" },
                    { city: "Sevilla", freq: "97.1", url: "https://playerservices.streamtheworld.com/api/livestream-redirect/LOS40.mp3" },
                    { city: "Murcia", freq: "91.3", url: "https://playerservices.streamtheworld.com/api/livestream-redirect/LOS40.mp3" }
                ]
            },
            {
                name: "CADENA 100", color: "#00CCFF",
                // Convertido a HLS puro
                locations: [
                    { city: "Elche", freq: "100.8", url: "https://cadena100-cope.flumotion.com/chunks.m3u8" },
                    { city: "Madrid", freq: "99.5", url: "https://cadena100-cope.flumotion.com/chunks.m3u8" },
                    { city: "Barcelona", freq: "100.0", url: "https://cadena100-cope.flumotion.com/chunks.m3u8" },
                    { city: "Valencia", freq: "99.0", url: "https://cadena100-cope.flumotion.com/chunks.m3u8" },
                    { city: "Sevilla", freq: "100.3", url: "https://cadena100-cope.flumotion.com/chunks.m3u8" },
                    { city: "Murcia", freq: "89.7", url: "https://cadena100-cope.flumotion.com/chunks.m3u8" }
                ]
            },
            {
                name: "DIAL", color: "#119911",
                locations: [
                    { city: "Alicante", freq: "96.5", url: "https://playerservices.streamtheworld.com/api/livestream-redirect/CADENADIAL.mp3" },
                    { city: "Madrid", freq: "91.7", url: "https://playerservices.streamtheworld.com/api/livestream-redirect/CADENADIAL.mp3" },
                    { city: "Barcelona", freq: "99.4", url: "https://playerservices.streamtheworld.com/api/livestream-redirect/CADENADIAL.mp3" },
                    { city: "Valencia", freq: "98.4", url: "https://playerservices.streamtheworld.com/api/livestream-redirect/CADENADIAL.mp3" },
                    { city: "Sevilla", freq: "102.4", url: "https://playerservices.streamtheworld.com/api/livestream-redirect/CADENADIAL.mp3" },
                    { city: "Murcia", freq: "103.1", url: "https://playerservices.streamtheworld.com/api/livestream-redirect/CADENADIAL.mp3" }
                ]
            },
            {
                name: "EUROPA FM", color: "#FF6600", 
                locations: [
                    { city: "Alicante", freq: "93.6", url: "https://atres-live.europafm.com/live/europafm/bitrate_1.m3u8" },
                    { city: "Madrid", freq: "91.0", url: "https://atres-live.europafm.com/live/europafm/bitrate_1.m3u8" },
                    { city: "Barcelona", freq: "94.9", url: "https://atres-live.europafm.com/live/europafm/bitrate_1.m3u8" },
                    { city: "Valencia", freq: "103.2", url: "https://atres-live.europafm.com/live/europafm/bitrate_1.m3u8" },
                    { city: "Sevilla", freq: "89.2", url: "https://atres-live.europafm.com/live/europafm/bitrate_1.m3u8" },
                    { city: "Murcia", freq: "101.0", url: "https://atres-live.europafm.com/live/europafm/bitrate_1.m3u8" }
                ]
            }
        ];

        let currentBrandIndex = 0;
        let isPlaying = false;
        let sleepTimeout;
        let hlsInstance = null; 
        
        const player = document.getElementById('radioPlayer');
        const playBtn = document.getElementById('playBtn');
        const displayScreen = document.getElementById('displayScreen');
        const stationName = document.getElementById('stationName');
        const freqDisplay = document.getElementById('freqDisplay');
        const dial = document.getElementById('freqDial');
        const citySelect = document.getElementById('citySelect');
        const alertBox = document.getElementById('adblockAlert');

        window.onload = () => { loadStation(0, 0); };

        function loadStation(brandIndex, locIndex) {
            currentBrandIndex = brandIndex;
            const station = stations[brandIndex];
            const loc = station.locations[locIndex];
            
            // Ocultar alerta inicial
            alertBox.style.display = "none";

            // Interfaz
            stationName.innerText = station.name;
            stationName.style.color = station.color;
            stationName.style.textShadow = `0 0 15px ${station.color}`;
            freqDisplay.innerText = `📍 ${loc.city} | FM ${loc.freq} MHz`;
            
            document.documentElement.style.setProperty('--accent', station.color);
            document.documentElement.style.setProperty('--brand-color', station.color);
            dial.value = brandIndex;

            // Desplegable
            citySelect.innerHTML = "";
            station.locations.forEach((l, idx) => {
                const opt = document.createElement("option");
                opt.value = idx;
                opt.innerText = idx === 0 ? `▶ ${l.city} (Local)` : l.city;
                if(idx === parseInt(locIndex)) opt.selected = true;
                citySelect.appendChild(opt);
            });

            // Limpieza
            if(hlsInstance) {
                hlsInstance.destroy();
                hlsInstance = null;
            }
            player.src = "";

            // Manejo de Error para Flumotion (Bloqueadores)
            player.onerror = function() {
                if(loc.url.includes("flumotion")) {
                    alertBox.style.display = "block";
                    stopRadio();
                }
            };

            // Reproducción
            if (loc.url.includes('.m3u8')) {
                if (Hls.isSupported()) {
                    hlsInstance = new Hls();
                    hlsInstance.on(Hls.Events.ERROR, function (event, data) {
                        if (data.fatal && loc.url.includes("flumotion")) {
                            alertBox.style.display = "block";
                            stopRadio();
                        }
                    });
                    hlsInstance.loadSource(loc.url);
                    hlsInstance.attachMedia(player);
                } else if (player.canPlayType('application/vnd.apple.mpegurl')) {
                    player.src = loc.url; 
                }
            } else {
                player.src = loc.url;
            }
            
            if (isPlaying) {
                player.play().catch(e => console.log("Previniendo autoplay"));
            }
        }

        function dialChanged() { loadStation(parseInt(dial.value), 0); }
        function setStation(brandIndex) { loadStation(brandIndex, 0); if(!isPlaying) togglePlay(); }
        function changeCity(locIndex) { loadStation(currentBrandIndex, parseInt(locIndex)); if(isPlaying) { player.pause(); player.play(); } else { togglePlay(); } }

        function togglePlay() {
            if (isPlaying) {
                player.pause();
                isPlaying = false;
                playBtn.innerText = "▶";
                playBtn.classList.remove('active');
                displayScreen.classList.remove('playing');
            } else {
                player.play().then(() => {
                    isPlaying = true;
                    playBtn.innerText = "⏸";
                    playBtn.classList.add('active');
                    displayScreen.classList.add('playing');
                }).catch(e => {
                    // Fallback visual si el navegador lo tumba
                    if(stations[currentBrandIndex].url && stations[currentBrandIndex].url.includes("flumotion")) {
                        alertBox.style.display = "block";
                    }
                });
            }
        }

        function stopRadio() {
            player.pause();
            if(hlsInstance) { hlsInstance.destroy(); hlsInstance = null; }
            player.src = ""; 
            isPlaying = false;
            playBtn.innerText = "▶";
            playBtn.classList.remove('active');
            displayScreen.classList.remove('playing');
            setTimeout(() => { loadStation(currentBrandIndex, parseInt(citySelect.value)); }, 500);
        }

        function toggleMute() {
            player.muted = !player.muted;
            const muteBtn = document.getElementById('muteBtn');
            muteBtn.innerText = player.muted ? "🔇" : "🔊";
            muteBtn.classList.toggle('active', player.muted);
        }

        function setSleepTimer(minutes) {
            clearTimeout(sleepTimeout);
            const indicator = document.getElementById('sleepIndicator');
            if (minutes === 0) { indicator.style.display = 'none'; return; }
            indicator.innerText = `ZZZ ${minutes}m`;
            indicator.style.display = 'block';
            sleepTimeout = setTimeout(() => { stopRadio(); indicator.style.display = 'none'; }, minutes * 60000);
        }
    </script>
</body>
</html>
